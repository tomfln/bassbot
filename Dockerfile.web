FROM oven/bun AS base
WORKDIR /app

# ── Dependencies ──
FROM base AS deps
COPY package.json bun.lock ./
COPY web/package.json web/
RUN bun install --frozen-lockfile

# ── Build ──
FROM base AS builder
# Copy full repo (web imports @bot/* and @lib/* types from bot source)
COPY . .
# Overlay installed node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/web/node_modules ./web/node_modules
WORKDIR /app/web
ENV NEXT_TELEMETRY_DISABLED=1
# Run next build directly — the prebuild (generate-commands-json) requires
# bot runtime config that isn't available at image build time.
# commands.json is committed to web/src/assets/ and kept up-to-date in CI.
RUN bun run next build

# ── Production ──
FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV DATA_DIR=/data

RUN useradd --system --uid 1001 nextjs \
 && mkdir -p /data && chown nextjs /data

COPY --from=builder /app/web/public ./public
COPY --from=builder --chown=nextjs /app/web/.next/standalone ./
COPY --from=builder --chown=nextjs /app/web/.next/static ./.next/static

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
CMD ["bun", "server.js"]
