FROM oven/bun AS base
WORKDIR /app

# ── Dependencies ──
FROM base AS deps
COPY package.json bun.lock ./
COPY web/package.json web/
RUN bun install --frozen-lockfile

# ── Build ──
FROM base AS builder
# Copy full repo (web imports @bot/* and @lib/* types from bot source)
COPY . .
# Overlay installed node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/web/node_modules ./web/node_modules
WORKDIR /app/web
ENV NEXT_TELEMETRY_DISABLED=1
# Run next build directly — the prebuild (generate-commands-json) requires
# bot runtime config that isn't available at image build time.
# commands.json is committed to web/src/assets/ and kept up-to-date in CI.
RUN bun run next build

# ── Production ──
# With outputFileTracingRoot pointing to repo root, standalone
# preserves the web/ + lib/ directory layout.
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV DATA_DIR=/data

# create runtime user
RUN useradd --system --uid 1001 --create-home --shell /usr/sbin/nologin nextjs \
 && mkdir -p /data

# entrypoint
COPY docker/web-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

COPY --from=builder /app/web/public ./web/public
COPY --from=builder --chown=nextjs /app/web/.next/standalone ./
COPY --from=builder --chown=nextjs /app/web/.next/static ./web/.next/static

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bun", "web/server.js"]