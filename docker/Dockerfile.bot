FROM oven/bun
WORKDIR /app

ENV DATA_DIR=/data
RUN mkdir -p /data && chown -R bun:bun /data

# Install workspace dependencies
COPY package.json bun.lock ./
COPY web/package.json web/
RUN bun install --frozen-lockfile

# Copy source
COPY tsconfig.json ./
COPY lib/ lib/
COPY src/ src/
COPY drizzle/ drizzle/

USER bun
CMD ["bun", "start"]
