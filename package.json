{
  "name": "bassbot",
  "version": "1.4.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "eslint": "turbo run eslint",
    "test": "turbo run test",
    "g": "bun run apps/bot/scripts/generate.ts",
    "register": "bun run apps/bot/scripts/register-commands.ts",
    "gen:commands": "turbo run gen:commands --filter=@bassbot/bot",
    "ci:docker-check": "bun packages/scripts/docker-publish-check.ts",
    "build-bot": "docker build -t bassbot:latest -f docker/Dockerfile.bot .",
    "build-web": "docker build -t bassbot-web:latest -f docker/Dockerfile.web .",
    "build-docker": "bun run build-bot && bun run build-web"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "prettier": "^3.8.1"
  },
  "prettier": "@bassbot/config/prettier",
  "packageManager": "bun@1.3.5"
}
