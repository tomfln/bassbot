{
  "name": "bassbot",
  "version": "1.4.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "eslint": "turbo run eslint",
    "test": "turbo run test",
    "g": "turbo run g --filter=@bassbot/bot",
    "register": "turbo run register --filter=@bassbot/bot",
    "gen:commands": "turbo run gen:commands --filter=@bassbot/bot",
    "ci:docker-check": "bun apps/bot/scripts/docker-publish-check.ts",
    "build-bot": "docker build -t bassbot:latest -f docker/Dockerfile.bot .",
    "build-web": "docker build -t bassbot-web:latest -f docker/Dockerfile.web .",
    "build-docker": "bun run build-bot && bun run build-web"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "prettier": "^3.8.1"
  },
  "prettier": "@bassbot/config/prettier",
  "packageManager": "bun@1.3.5"
}
