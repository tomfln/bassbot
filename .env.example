# ═══════════════════════════════════════════════════════════════
# BassBot — Environment Variables
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ── Bot ───────────────────────────────────────────────────────
# Discord bot token (Developer Portal > Bot)
DISCORD_BOT_TOKEN=
# Discord application ID (Developer Portal > General Information)
DISCORD_APP_ID=
# Watch2Gether API key (optional)
# W2G_KEY=

# ── Lavalink ──────────────────────────────────────────────────
# Primary lavalink node
LAVALINK_HOST=lavalink:2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_NAME=main
# LAVALINK_SECURE=false
#
# Additional nodes (increment the suffix: _1, _2, …)
# LAVALINK_HOST_1=
# LAVALINK_PASSWORD_1=
# LAVALINK_NAME_1=node1
#
# Alternatively, place a nodes.json in the data directory.

# ── Shared (bot + web) ───────────────────────────────────────
# JWT secret for auth between bot and web (generate: openssl rand -hex 32)
JWT_SECRET=
# Public URL where the web dashboard is accessible
WEB_BASE_URL=http://localhost:3000

# ── Web Dashboard ────────────────────────────────────────────
# Discord OAuth client secret (Developer Portal > OAuth2)
DISCORD_OAUTH_CLIENT_SECRET=
# BetterAuth encryption secret (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET=
# Comma-separated Discord usernames auto-promoted to admin
# ADMIN_USERS=alice,bob

# ── Paths / Ports (defaults are usually fine) ────────────────
# DATA_DIR=./data
# API_PORT=3001
# API_ENABLED=true
# API_URL=
# DATABASE_PATH=

# ── Docker Compose volumes ────────────────────────────────────
# DATA_PATH=./bassbot-data
# LAVALINK_CONFIG=./bassbot-data/application.yml
