# ── Bot ──────────────────────────────────────────────────────
# Discord bot token (from Discord Developer Portal > Bot)
DISCORD_BOT_TOKEN=
# Discord application ID (Developer Portal > General Information)
# Used for both bot command registration and web OAuth
DISCORD_APP_ID=
# Watch2Gether API key
W2G_KEY=
# Bot REST API port (default: 3001)
# API_PORT=3001
# Enable/disable bot REST API (default: true)
# API_ENABLED=true

# ── Shared (bot + web) ───────────────────────────────────────
# JWT secret for auth between bot and web dashboard
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Path to shared data directory containing config.json
# DATA_DIR=./data

# ── Web dashboard ────────────────────────────────────────────
# Discord application ID (same as DISCORD_APP_ID — only needed when
# running the web separately without a shared config.json)
# DISCORD_APP_ID=
# Discord OAuth client secret (Developer Portal > OAuth2)
DISCORD_OAUTH_CLIENT_SECRET=
# BetterAuth encryption secret (>= 32 chars)
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Public URL where the web dashboard is accessible
BETTER_AUTH_URL=http://localhost:3000
# (Optional) Bot API URL — only set this if the bot API is on a different
# domain than the web dashboard.  When both run on the same domain behind
# a reverse proxy, leave this empty (the browser uses the same origin).
# API_URL=
# (Optional) Override SQLite database path (defaults to <DATA_DIR>/web.db)
# DATABASE_PATH=
