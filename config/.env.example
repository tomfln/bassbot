# ═══════════════════════════════════════════════════════════════
# BassBot — Docker Compose Environment
# Copy this file to .env and fill in the required values.
# Docker Compose reads this automatically from the same directory.
# ═══════════════════════════════════════════════════════════════

# ── Discord (required) ────────────────────────────────────────
# Bot token (Developer Portal > Bot)
DISCORD_BOT_TOKEN=
# Application ID (Developer Portal > General Information)
DISCORD_APP_ID=
# OAuth client secret (Developer Portal > OAuth2)
DISCORD_OAUTH_CLIENT_SECRET=

# ── Secrets (required — generate with: openssl rand -hex 32) ─
JWT_SECRET=
BETTER_AUTH_SECRET=

# ── Web Dashboard ─────────────────────────────────────────────
# Public URL where the dashboard is accessible
WEB_BASE_URL=http://localhost:3000

# ── Lavalink ──────────────────────────────────────────────────
# the password will overwrite the one set in application.yml
LAVALINK_HOST=lavalink:2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_NAME=main
LAVALINK_SECURE=false

# ── Optional ──────────────────────────────────────────────────
# Watch2Gether API key
# W2G_KEY=
# Comma-separated Discord usernames auto-promoted to admin
ADMIN_USERS=
# Bot API URL from the browser (only needed when bot is on a different domain)
# API_URL=

# ── Ports ─────────────────────────────────────────────────────
API_PORT=3001
API_ENABLED=true
WEB_PORT=3000

# ── Volume Paths ──────────────────────────────────────────────
# Bind-mount paths for persistent data and Lavalink config.
# Set to absolute paths in production (e.g. /opt/bassbot/data).
BOT_DATA_PATH=./bot
WEB_DATA_PATH=./web
LAVALINK_CONFIG=./application.yml
